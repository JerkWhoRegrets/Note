import java.io.*;
import java.util.*;

public class Main {

    public static void main(String[] args) throws Exception {
        FastScanner fs = new FastScanner(System.in);

        int n = fs.nextInt();
        int m = fs.nextInt();

        int[] first = new int[n];
        int[] second = new int[m];

        Set<Integer> setFirst = new HashSet<>();
        Set<Integer> setSecond = new HashSet<>();

        for (int i = 0; i < n; i++) {
            first[i] = fs.nextInt();
            setFirst.add(first[i]);
        }

        for (int i = 0; i < m; i++) {
            second[i] = fs.nextInt();
            setSecond.add(second[i]);
        }

        int count = 0;

        for (int value : first) {
            if (!setSecond.contains(value)) {
                count++;
            }
        }

        for (int value : second) {
            if (!setFirst.contains(value)) {
                count++;
            }
        }

        System.out.println(count);
    }

    static class FastScanner {
        private final InputStream in;
        private final byte[] buffer = new byte[1 << 16];
        private int ptr = 0, len = 0;

        FastScanner(InputStream in) {
            this.in = in;
        }

        private int read() throws IOException {
            if (ptr >= len) {
                len = in.read(buffer);
                ptr = 0;
                if (len <= 0) return -1;
            }
            return buffer[ptr++];
        }

        int nextInt() throws IOException {
            int c;
            do {
                c = read();
            } while (c <= ' ' && c != -1);

            int sign = 1;
            if (c == '-') {
                sign = -1;
                c = read();
            }

            int value = 0;
            while (c > ' ') {
                value = value * 10 + (c - '0');
                c = read();
            }

            return value * sign;
        }
    }
}