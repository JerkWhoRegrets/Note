import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.StringTokenizer;

class Solution {

    public static void main(String[] args) throws Exception {
        FastScanner fs = new FastScanner();

        double x1 = fs.nextDouble();
        double y1 = fs.nextDouble();
        double r1 = fs.nextDouble();

        double x2 = fs.nextDouble();
        double y2 = fs.nextDouble();
        double r2 = fs.nextDouble();

        double area = intersectionArea(x1, y1, r1, x2, y2, r2);
        System.out.printf("%.6f%n", area);
    }

    private static double intersectionArea(double x1, double y1, double r1,
                                           double x2, double y2, double r2) {
        double dx = x1 - x2;
        double dy = y1 - y2;
        double d = Math.sqrt(dx * dx + dy * dy);

        if (d >= r1 + r2) {
            return 0.0;
        }

        if (d <= Math.abs(r1 - r2)) {
            double smallerRadius = Math.min(r1, r2);
            return Math.PI * smallerRadius * smallerRadius;
        }

        double angle1 = Math.acos(clamp((d * d + r1 * r1 - r2 * r2) / (2.0 * d * r1)));
        double angle2 = Math.acos(clamp((d * d + r2 * r2 - r1 * r1) / (2.0 * d * r2)));

        double area1 = r1 * r1 * angle1;
        double area2 = r2 * r2 * angle2;
        double triangleArea = 0.5 * Math.sqrt(
                (-d + r1 + r2) *
                (d + r1 - r2) *
                (d - r1 + r2) *
                (d + r1 + r2)
        );

        return area1 + area2 - triangleArea;
    }

    private static double clamp(double value) {
        if (value < -1.0) return -1.0;
        if (value > 1.0) return 1.0;
        return value;
    }

    static class FastScanner {
        private final BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        private StringTokenizer st;

        double nextDouble() throws IOException {
            while (st == null || !st.hasMoreTokens()) {
                st = new StringTokenizer(br.readLine());
            }
            return Double.parseDouble(st.nextToken());
        }
    }
}